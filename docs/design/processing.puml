@startuml processing message via transaction_closed topic
start
  :Make GET request to Transaction API and obtain response;
  while (More responses to process?) is (yes)
    :Make GET request to filing API with link data extracted from response and get filing response;
    while (More filing responses to process?) is (yes)
      if (new Submission?) then (yes)
        :Add request to list of request to be PATCH;
      else (no)
        :Continue processing;
      endif
    endwhile
  if (any PATCH request?) then (yes)
    :Call patch;
  else (no)
    :Continue processing;
  endif
  :Produce Message to filing_received topic ;
stop
@enduml