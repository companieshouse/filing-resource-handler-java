@startuml
start
repeat
  :Read from topic;
  :Process message;
  if (Processing successful?) then (no)
    :Increment attempt number;
    if (Attempt < threshold?) then (yes)
      :Send to retry topic;
    else (no)
      :Send to error topic;
    endif
  else (yes)
    :Make GET request with data and obtain response;
    while (More responses to process?) is (yes)
      :Make GET request with link data extracted from response and get filing response;
      while (More filing responses to process?) is (yes)
        if (new Submission?) then (yes)
          :Add request to list of request to be PATCH;
        endif
      endwhile
    endwhile
    :If any PATCH request then call patch;
    :Produce Message;
  endif
repeat while (Attempt < threshold?)
stop
@enduml